generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

enum Role {
  STUDENT
  TUTOR
  RESEARCHER
  ADMIN
}

enum EducationLevel {
  HIGH_SCHOOL
  COLLEGE
  GENERAL
}

model User {
  id                     String    @id
  email                  String    @unique
  firstName              String
  lastName               String
  role                   Role      @default(STUDENT)
  isVerified             Boolean   @default(false)
  qualification          String?
  institution            String?
  address                String?
  currency               String    @default("KES")
  paystackSubaccountCode String?
  isProfileComplete      Boolean   @default(false)
  isSubscribed           Boolean   @default(false)
  subscriptionPlan       String?
  paystackSubId          String?   @unique
  trialEndsAt            DateTime?

  wallet             Wallet?
  notesCreated       Note[]              @relation("AuthorNotes")
  projectsCreated    Project[]           @relation("AuthorProjects")
  purchases          Purchase[]
  purchasedNotes     Note[]              @relation("UserPurchases")
  purchasedProjects  Project[]           @relation("UserProjectPurchases")
  createdExams       Exam[]              @relation("CreatedExams")
  examAttempts       ExamAttempt[]
  studentRequests    MaterialRequest[]   @relation("StudentRequests")
  tutorRequests      MaterialRequest[]   @relation("TutorRequests")
  communityQuestions CommunityQuestion[] @relation("UserCommunityQuestions")
  communityAnswers   CommunityAnswer[]   @relation("UserCommunityAnswers")
  transactions       Transaction[]       @relation("UserTransactions")

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([email])
}

model Wallet {
  id        String   @id @default(cuid())
  balance   Decimal  @default(0.00) @db.Decimal(10, 2)
  userId    String   @unique
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([userId])
}

model Subject {
  id                 String              @id @default(cuid())
  name               String              @unique
  description        String?
  notes              Note[]
  projects           Project[]
  exams              Exam[]
  communityQuestions CommunityQuestion[]
  createdAt          DateTime            @default(now())
  updatedAt          DateTime            @updatedAt
}

model Note {
  id           String         @id @default(cuid())
  title        String
  description  String
  contentUrl   String
  thumbnailUrl String?
  price        Decimal        @default(0.00) @db.Decimal(10, 2)
  level        EducationLevel
  isPublished  Boolean        @default(false)

  authorId     String
  author       User       @relation("AuthorNotes", fields: [authorId], references: [id], onDelete: Restrict)
  subjectId    String
  subject      Subject    @relation(fields: [subjectId], references: [id], onDelete: Restrict)
  purchases    Purchase[]
  purchasers   User[]     @relation("UserPurchases")

  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  @@index([subjectId])
  @@index([authorId])
}

model Project {
  id            String         @id @default(cuid())
  title         String
  description   String         @db.Text
  price         Decimal        @default(0.00) @db.Decimal(10, 2)
  techStack     String[]
  demoUrl       String?
  documentUrl   String?
  sourceCodeUrl String?
  thumbnailUrl  String?
  level         EducationLevel
  isPublished   Boolean        @default(false)

  authorId      String
  author        User       @relation("AuthorProjects", fields: [authorId], references: [id], onDelete: Restrict)
  subjectId     String
  subject       Subject    @relation(fields: [subjectId], references: [id], onDelete: Restrict)
  purchases     Purchase[]
  purchasers    User[]     @relation("UserProjectPurchases")

  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  @@index([subjectId])
  @@index([authorId])
}

model Purchase {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  noteId    String?
  note      Note?    @relation(fields: [noteId], references: [id], onDelete: Restrict)
  projectId String?
  project   Project? @relation(fields: [projectId], references: [id], onDelete: Restrict)
  amount    Decimal  @db.Decimal(10, 2)
  reference String   @unique

  createdAt DateTime @default(now())

  @@index([userId])
  @@index([noteId])
  @@index([projectId])
}

model Exam {
  id             String         @id @default(cuid())
  title          String
  description    String?
  level          EducationLevel
  type           String
  duration       Int?
  questionsCount Int            @default(0)
  isPublished    Boolean        @default(false)

  subjectId      String
  subject        Subject       @relation(fields: [subjectId], references: [id])
  authorId       String
  author         User          @relation("CreatedExams", fields: [authorId], references: [id])
  questions      Question[]
  attempts       ExamAttempt[]

  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  @@index([subjectId])
  @@index([authorId])
}

model Question {
  id          String   @id @default(cuid())
  text        String   @db.Text
  marks       Int      @default(1)
  explanation String?  @db.Text
  examId      String
  exam        Exam     @relation(fields: [examId], references: [id], onDelete: Cascade)
  options     Option[]

  @@index([examId])
}

model Option {
  id         String   @id @default(cuid())
  text       String
  isCorrect  Boolean  @default(false)
  questionId String
  question   Question @relation(fields: [questionId], references: [id], onDelete: Cascade)

  @@index([questionId])
}

model ExamAttempt {
  id          String   @id @default(cuid())
  score       Int
  maxScore    Int
  completedAt DateTime @default(now())

  userId      String
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  examId      String
  exam        Exam     @relation(fields: [examId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([examId])
}

model MaterialRequest {
  id          String   @id @default(cuid())
  title       String
  description String   @db.Text
  format      String
  deadline    DateTime
  offerAmount Decimal  @db.Decimal(10, 2)
  status      String   @default("PENDING")
  fileUrl     String?

  studentId   String
  student     User     @relation("StudentRequests", fields: [studentId], references: [id])
  tutorId     String
  tutor       User     @relation("TutorRequests", fields: [tutorId], references: [id])

  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([studentId])
  @@index([tutorId])
}

model CommunityQuestion {
  id         String   @id @default(cuid())
  title      String
  body       String   @db.Text
  isResolved Boolean  @default(false)
  views      Int      @default(0)

  authorId   String
  author     User     @relation("UserCommunityQuestions", fields: [authorId], references: [id], onDelete: Cascade)
  subjectId  String?
  subject    Subject? @relation(fields: [subjectId], references: [id], onDelete: SetNull)
  answers    CommunityAnswer[]

  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@index([subjectId])
  @@index([authorId])
}

model CommunityAnswer {
  id         String   @id @default(cuid())
  body       String   @db.Text
  isAccepted Boolean  @default(false)
  upvotes    Int      @default(0)

  authorId   String
  author     User     @relation("UserCommunityAnswers", fields: [authorId], references: [id], onDelete: Cascade)
  questionId String
  question   CommunityQuestion @relation(fields: [questionId], references: [id], onDelete: Cascade)

  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@index([questionId])
  @@index([authorId])
}

model Transaction {
  id          String   @id @default(cuid())
  reference   String   @unique
  amount      Decimal  @db.Decimal(10, 2)
  type        String
  description String?

  userId      String
  user        User     @relation("UserTransactions", fields: [userId], references: [id], onDelete: Cascade)

  createdAt   DateTime @default(now())

  @@index([userId])
}